# Supabase（後で本番/ローカルの値を設定）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 決済（Stripe 想定。香典・供花決済で使用）
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# 決済を実際にオンにする明示フラグ（"1"で有効）。鍵を入れただけでは有効化されない。
OFFERING_PAYMENT_ENABLED=1
# KODEN_PAYMENT_ENABLED=1   # 香典のカード決済（現状はオフのまま。使うときだけ"1"）

# アプリURL（共有リンク生成・メール用）
NEXT_PUBLIC_APP_URL=http://localhost:3000
